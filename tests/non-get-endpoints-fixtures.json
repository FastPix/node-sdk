      "request": {
        "mediaId": "REPLACE_WITH_REAL_MEDIA_ID",
        "url": "https://static.fastpix.com/sample.vtt",
        "type": "subtitle",
        "languageCode": "en",
        "languageName": "English",
        "closedCaptions": true
      }
    },

    "cancel-upload": {
      "description": "Cancel an in-progress resumable upload.",
      "skip": true,
      "reason": "Needs a real uploadId from a still-active upload session.",
      "request": { "uploadId": "REPLACE_WITH_REAL_UPLOAD_ID" }
