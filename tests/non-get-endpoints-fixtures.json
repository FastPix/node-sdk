{
  "_help": "Fixtures for validate-non-get-endpoints.ts. Each entry's `request` is passed verbatim as the second arg to the SDK method invoker (the SDK accepts a single object combining path params, query params, and body). Set `skip: true` to keep the entry for documentation but not execute it. Operations not listed here are skipped by default.",
  "operations": {
    "create-media": {
      "description": "Create a new on-demand media asset from a public URL.",
      "request": {
        "inputs": [
          {
            "type": "video",
            "url": "https://static.fastpix.com/fp-sample-video.mp4"
          }
        ],
        "metadata": { "source": "non-get-validator" },
        "accessPolicy": "public",
        "maxResolution": "720p"
      }
    },

    "direct-upload-video-media": {
      "description": "Mint a signed URL for a direct browser upload. Non-destructive.",
      "request": {
        "corsOrigin": "*",
        "pushMediaSettings": {
          "accessPolicy": "public",
          "metadata": { "source": "non-get-validator" }
        }
      }
    },

    "create-a-playlist": {
      "description": "Create a manual playlist.",
      "request": {
        "name": "Non-GET Validator Playlist",
        "type": "manual",
        "referenceId": "nonGetValidatorPlaylist",
        "description": "Created by validate non get endpoints",
        "mediaIds": [],
        "metadata": {}
      }
    },

    "create-new-stream": {
      "description": "Create a new live stream. Costs nothing until it goes live.",
      "request": {
        "metadata": { "source": "non-get-validator" },
        "playbackSettings": { "accessPolicy": "public" },
        "inputMediaSettings": {
          "maxResolution": "1080p",
          "reconnectWindow": 60,
          "mediaPolicy": "public"
        }
      }
    },

    "create_signing_key": {
      "description": "Create a new signing key for JWT minting.",
      "request": {}
    },

    "updated-media": {
      "description": "Update metadata on an existing media. Needs a real mediaId.",
      "skip": true,
      "reason": "Set mediaId to a real ID, then remove `skip` to enable.",
      "request": {
        "mediaId": "REPLACE_WITH_REAL_MEDIA_ID",
        "metadata": { "updatedBy": "non-get-validator" }
      }
    },

    "delete-media": {
      "description": "Permanently deletes a media.",
      "skip": true,
      "reason": "Destructive. Provide a real, expendable mediaId before enabling.",
      "request": { "mediaId": "REPLACE_WITH_REAL_MEDIA_ID" }
    },

